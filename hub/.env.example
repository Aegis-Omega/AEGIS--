# Lemon Squeezy checkout links (set after creating products at app.lemonsqueezy.com)
# Redirect URL for each product must be set to:
#   Single:  https://aegis-hub.vercel.app/success?plan=single
#   Starter: https://aegis-hub.vercel.app/success?plan=starter
#   Full:    https://aegis-hub.vercel.app/success?plan=full
VITE_LS_LINK_SINGLE=
VITE_LS_LINK_STARTER=
VITE_LS_LINK_FULL=

# Tool deployment URLs (already set as defaults in code)
VITE_URL_PLATFORM_PICKER=https://aegis-platform-picker.vercel.app
VITE_URL_HOOK_GENERATOR=https://aegis-hook-generator.vercel.app
VITE_URL_CONTENT_CALENDAR=https://aegis-content-calendar.vercel.app

# Supabase backend (aegis-omega project, eu-central-1)
VITE_SUPABASE_URL=https://rwehltdwpsncnwxzkwik.supabase.co
